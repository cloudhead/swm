CompileFlags:
  Compiler: clang
  Add:
    - -std=c23
    - -I.
    - -I/usr/include/wlroots-0.20
    - -I/usr/include/pixman-1
    - -I/usr/include/libdrm
    - -DWLR_USE_UNSTABLE
    - -D_POSIX_C_SOURCE=200809L
    - -DVERSION="1.0.0"

---
If:
  PathMatch: .*\.h
CompileFlags:
  Add:
    - -xc

---
If:
  PathMatch: config(\.def)?\.h
Diagnostics:
  Suppress: "*"
